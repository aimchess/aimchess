// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  COACH
  STUDENT
}

enum Stage {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(STUDENT)

  // Student-specific fields
  stage     Stage    @default(BEGINNER)
  coachId   String?
  coach     User?    @relation("CoachStudents", fields: [coachId], references: [id], onDelete: SetNull)
  students  User[]   @relation("CoachStudents") // Reverse relation for Coaches

  // Puzzle Relations
  assignments    Assignment[]
  puzzleProgress Progress[]

  // Course Relations
  courseProgress CourseProgress[]
  status String @default("ACTIVE")

  // New Student Fields
  joiningDate DateTime?
  birthDate   DateTime?
  address     String?
  parentName  String?
  parentPhone String?
  photoUrl    String? @db.Text
  idCardUrl   String? @db.Text

  // Attendance Relations
  managedClasses ClassTiming[] @relation("CoachClasses")
  classes        ClassTiming[] @relation("StudentClasses")
  attendanceRecords Attendance[]

  // Fee Payment Relations
  feePayments    FeePayment[]

  // MCQ Progress
  mcqProgress    MCQProgress[]

  // Live Play & Tournament Relations
  challengesSent Challenge[] @relation("Challenger")
  challengesReceived Challenge[] @relation("Challenged")
  whiteGames     Game[] @relation("WhitePlayer")
  blackGames     Game[] @relation("BlackPlayer")
  tournamentParticipations TournamentParticipant[]
  performanceReports PerformanceReport[]
  lastActiveAt DateTime?

  // Phase 2: AIM Rating & Clubs
  aimRating       Int      @default(500)
  highestAimRating Int     @default(500)
  wins            Int      @default(0)
  losses          Int      @default(0)
  draws           Int      @default(0)
  aimRatingHistory Json    @default("[]") // Array of { rating: number, date: string }
  aimClub         String   @default("Beginner")
  aimLevel        String   @default("Starter Level")
  aimClubDate     DateTime?

  // Certificates & Notifications
  certificates    Certificate[]
  notifications   Notification[]
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
}

model ClassTiming {
  id          String   @id @default(uuid())
  name        String
  dayOfWeek   String   // e.g., "Monday", "Tuesday"
  startTime   String   // e.g., "17:00"
  endTime     String   // e.g., "18:30"
  
  coachId     String
  coach       User     @relation("CoachClasses", fields: [coachId], references: [id], onDelete: Cascade)
  
  students    User[]   @relation("StudentClasses")
  attendance  Attendance[]
  meetingLink String?   @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id            String           @id @default(uuid())
  date          DateTime         // The date of the session
  status        AttendanceStatus
  remarks       String?          @db.Text
  
  studentId     String
  student       User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  classTimingId String
  classTiming   ClassTiming      @relation(fields: [classTimingId], references: [id], onDelete: Cascade)

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([studentId, classTimingId, date])
}

// ==========================================
// 1. PUZZLE SYSTEM (Existing)
// ==========================================

model Folder {
  id        String   @id @default(uuid())
  name      String

  stage     Stage?   // only root folders have stage
  parentId  String?
  parent    Folder?  @relation("SubFolders", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("SubFolders")

  puzzles   Puzzle[]
  mcqs      MCQ[]
}

model MCQ {
  id             String        @id @default(uuid())
  position       String        @db.Text // Chess FEN string
  question       String        @db.Text
  options        Json          // Array of strings
  explanation    String?       @db.Text
  stage          Stage         @default(BEGINNER)
  folderId       String?
  createdAt      DateTime      @default(now())
  correctOptions Int[]         // Indices of correct answers
  folder         Folder?       @relation(fields: [folderId], references: [id], onDelete: Cascade)
  progress       MCQProgress[]
  assignments    Assignment[]
  puzzleId       String?
}

model MCQProgress {
  id        String  @id @default(uuid())
  studentId String
  mcqId     String
  isCorrect Boolean
  attempts  Int     @default(0)
  mcq       MCQ     @relation(fields: [mcqId], references: [id], onDelete: Cascade)
  student   User    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  @@unique([studentId, mcqId])
}

model Puzzle {
  id        String   @id @default(uuid())
  title     String
  fen       String   @db.Text
  solution  String   @db.Text // space separated moves
  data      Json?  

  folderId  String?  // Made optional in case a puzzle doesn't belong to a folder immediately
  folder    Folder?  @relation(fields: [folderId], references: [id], onDelete: Cascade)

  assignments Assignment[]
  progress    Progress[]
}

model Assignment {
  id          String   @id @default(uuid())

  studentId   String
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  puzzleId    String?
  puzzle      Puzzle?  @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  mcqId       String?
  mcq         MCQ?     @relation(fields: [mcqId], references: [id], onDelete: Cascade)

  assignedBy  String
  isCompleted Boolean  @default(false)
  assignedAt  DateTime @default(now())
  dueDate     DateTime?
  audioUrl    String?   @db.Text
}

// Tracks Puzzle history
model Progress {
  id          String   @id @default(uuid())

  studentId   String
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  puzzleId    String
  puzzle      Puzzle   @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  isSolved    Boolean  @default(false)
  attempts    Int      @default(0)
  timeSpent   Int      @default(0)
  mistakes    Json     @default("[]") 

  lastPlayed  DateTime @updatedAt

  @@unique([studentId, puzzleId])
}

// ==========================================
// 2. COURSE / CURRICULUM SYSTEM (New)
// ==========================================

model Course {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  level       Stage    @default(BEGINNER)
  
  // A course has many chapters
  chapters    Chapter[]
  
  // Track who is taking this course
  studentProgress CourseProgress[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  audioUrl    String?  @db.Text
}

model Chapter {
  id        String   @id @default(uuid())
  title     String
  content   String?  @db.Text // The script/notes for the coach or student
  fen       String   @db.Text // The board setup for this lesson
  
  order     Int      @default(0) // To keep chapters 1, 2, 3...

  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// Tracks Course completion
model CourseProgress {
  id        String   @id @default(uuid())

  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // Array of Chapter IDs that the student has completed
  completedChapters String[] 
  
  isCompleted       Boolean  @default(false)
  lastAccessed      DateTime @default(now())

  @@unique([studentId, courseId])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model FeePayment {
  id        String        @id @default(uuid())
  amount    Float
  date      DateTime      @default(now())
  status    PaymentStatus @default(PENDING)
  method    String        // e.g., "Cash", "UPI", "Bank Transfer"
  remarks   String?       @db.Text
  
  studentId String
  student   User          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// ==========================================
// 3. CHALLENGE & LIVE PLAY (New)
// ==========================================

enum ChallengeStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

model Challenge {
  id          String   @id @default(uuid())
  challengerId String
  challenger   User    @relation("Challenger", fields: [challengerId], references: [id], onDelete: Cascade)
  challengedId String
  challenged   User    @relation("Challenged", fields: [challengedId], references: [id], onDelete: Cascade)
  status      ChallengeStatus @default(PENDING)
  timeControl String?   // e.g. "10+0"
  isRated     Boolean   @default(false)
  gameId      String?   @unique
  game        Game?     @relation(fields: [gameId], references: [id])
  tournamentId String?
  tournament  Tournament? @relation(fields: [tournamentId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum GameStatus {
  IN_PROGRESS
  COMPLETED
  ABORTED
}

model Game {
  id          String   @id @default(uuid())
  whiteId     String
  white       User     @relation("WhitePlayer", fields: [whiteId], references: [id], onDelete: Cascade)
  blackId     String
  black       User     @relation("BlackPlayer", fields: [blackId], references: [id], onDelete: Cascade)
  pgn         String?  @db.Text
  fen         String?  @db.Text
  status      GameStatus @default(IN_PROGRESS)
  winnerId    String?
  result      String?  // e.g., "1-0", "0-1", "1/2-1/2"
  isRated     Boolean  @default(false)
  timeControl String?
  whiteTimeLeft Int?
  blackTimeLeft Int?
  lastMoveAt  DateTime?
  challenge   Challenge?
  tournamentId String?
  tournament  Tournament? @relation(fields: [tournamentId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 4. TOURNAMENT SYSTEM (New)
// ==========================================

model Tournament {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  startDate   DateTime
  endDate     DateTime?
  status      String   @default("UPCOMING") // UPCOMING, ONGOING, COMPLETED
  timeControl String?
  totalRounds Int      @default(4)
  pairingSystem String   @default("Swiss") // Swiss / Round Robin
  currentRound  Int      @default(1)
  participants TournamentParticipant[]
  games       Game[]
  challenges  Challenge[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TournamentParticipant {
  id           String     @id @default(uuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  score        Float      @default(0)
  joinedAt     DateTime   @default(now())
  @@unique([tournamentId, userId])
}

// ==========================================
// 5. PERFORMANCE REPORT SYSTEM (New)
// ==========================================

model PerformanceReport {
  id          String   @id @default(uuid())
  studentId   String
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  month       Int      // 1 to 12
  year        Int      // e.g. 2024
  attendancePoints Float @default(0) // max 40
  homeworkPoints   Float @default(0) // max 20
  assignmentPoints Float @default(0) // max 20
  tournamentPoints Float @default(0) // max 20
  totalPoints      Float @default(0) // max 100
  award            String? // Gold Star, Silver Star, Bronze Star, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([studentId, month, year])
}

model Certificate {
  id          String    @id @default(uuid())
  studentId   String
  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type        String    // GOLD_STAR, SILVER_STAR, BRONZE_STAR, AIM_CLUB
  clubName    String?
  status      String    @default("PENDING") // PENDING, ISSUED
  issuedAt    DateTime?
  createdAt   DateTime  @default(now())
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  message     String
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())
}