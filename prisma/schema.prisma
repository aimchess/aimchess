// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  COACH
  STUDENT
}

enum Stage {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(STUDENT)

  // Student-specific fields
  stage     Stage    @default(BEGINNER)
  coachId   String?
  coach     User?    @relation("CoachStudents", fields: [coachId], references: [id], onDelete: SetNull)
  students  User[]   @relation("CoachStudents") // Reverse relation for Coaches

  // Puzzle Relations
  assignments    Assignment[]
  puzzleProgress Progress[]

  // Course Relations
  courseProgress CourseProgress[]
  status String @default("ACTIVE")

  // New Student Fields
  joiningDate DateTime?
  birthDate   DateTime?
  address     String?
  parentName  String?
  parentPhone String?
  photoUrl    String? @db.Text
  idCardUrl   String? @db.Text

  // Attendance Relations
  managedClasses ClassTiming[] @relation("CoachClasses")
  classes        ClassTiming[] @relation("StudentClasses")
  attendanceRecords Attendance[]

  // Fee Payment Relations
  feePayments    FeePayment[]

  // MCQ Progress
  mcqProgress    MCQProgress[]
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
}

model ClassTiming {
  id          String   @id @default(uuid())
  name        String
  dayOfWeek   String   // e.g., "Monday", "Tuesday"
  startTime   String   // e.g., "17:00"
  endTime     String   // e.g., "18:30"
  
  coachId     String
  coach       User     @relation("CoachClasses", fields: [coachId], references: [id], onDelete: Cascade)
  
  students    User[]   @relation("StudentClasses")
  attendance  Attendance[]
  meetingLink String?   @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id            String           @id @default(uuid())
  date          DateTime         // The date of the session
  status        AttendanceStatus
  remarks       String?          @db.Text
  
  studentId     String
  student       User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  classTimingId String
  classTiming   ClassTiming      @relation(fields: [classTimingId], references: [id], onDelete: Cascade)

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([studentId, classTimingId, date])
}

// ==========================================
// 1. PUZZLE SYSTEM (Existing)
// ==========================================

model Folder {
  id        String   @id @default(uuid())
  name      String

  stage     Stage?   // only root folders have stage
  parentId  String?
  parent    Folder?  @relation("SubFolders", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("SubFolders")

  puzzles   Puzzle[]
  mcqs      MCQ[]
}

model MCQ {
  id             String        @id @default(uuid())
  position       String        @db.Text // Chess FEN string
  question       String        @db.Text
  options        Json          // Array of strings
  explanation    String?       @db.Text
  stage          Stage         @default(BEGINNER)
  folderId       String?
  createdAt      DateTime      @default(now())
  correctOptions Int[]         // Indices of correct answers
  folder         Folder?       @relation(fields: [folderId], references: [id], onDelete: Cascade)
  progress       MCQProgress[]
  assignments    Assignment[]
  puzzleId       String?
}

model MCQProgress {
  id        String  @id @default(uuid())
  studentId String
  mcqId     String
  isCorrect Boolean
  attempts  Int     @default(0)
  mcq       MCQ     @relation(fields: [mcqId], references: [id], onDelete: Cascade)
  student   User    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  @@unique([studentId, mcqId])
}

model Puzzle {
  id        String   @id @default(uuid())
  title     String
  fen       String   @db.Text
  solution  String   @db.Text // space separated moves
  data      Json?  

  folderId  String?  // Made optional in case a puzzle doesn't belong to a folder immediately
  folder    Folder?  @relation(fields: [folderId], references: [id], onDelete: Cascade)

  assignments Assignment[]
  progress    Progress[]
}

model Assignment {
  id          String   @id @default(uuid())

  studentId   String
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  puzzleId    String?
  puzzle      Puzzle?  @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  mcqId       String?
  mcq         MCQ?     @relation(fields: [mcqId], references: [id], onDelete: Cascade)

  assignedBy  String
  isCompleted Boolean  @default(false)
  assignedAt  DateTime @default(now())
  dueDate     DateTime?
  audioUrl    String?   @db.Text
}

// Tracks Puzzle history
model Progress {
  id          String   @id @default(uuid())

  studentId   String
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  puzzleId    String
  puzzle      Puzzle   @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  isSolved    Boolean  @default(false)
  attempts    Int      @default(0)
  timeSpent   Int      @default(0)
  mistakes    Json     @default("[]") 

  lastPlayed  DateTime @updatedAt

  @@unique([studentId, puzzleId])
}

// ==========================================
// 2. COURSE / CURRICULUM SYSTEM (New)
// ==========================================

model Course {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  level       Stage    @default(BEGINNER)
  
  // A course has many chapters
  chapters    Chapter[]
  
  // Track who is taking this course
  studentProgress CourseProgress[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  audioUrl    String?  @db.Text
}

model Chapter {
  id        String   @id @default(uuid())
  title     String
  content   String?  @db.Text // The script/notes for the coach or student
  fen       String   @db.Text // The board setup for this lesson
  
  order     Int      @default(0) // To keep chapters 1, 2, 3...

  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// Tracks Course completion
model CourseProgress {
  id        String   @id @default(uuid())

  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // Array of Chapter IDs that the student has completed
  completedChapters String[] 
  
  isCompleted       Boolean  @default(false)
  lastAccessed      DateTime @default(now())

  @@unique([studentId, courseId])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model FeePayment {
  id        String        @id @default(uuid())
  amount    Float
  date      DateTime      @default(now())
  status    PaymentStatus @default(PENDING)
  method    String        // e.g., "Cash", "UPI", "Bank Transfer"
  remarks   String?       @db.Text
  
  studentId String
  student   User          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}